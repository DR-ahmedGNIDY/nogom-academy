{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "flutter-web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": [
        "run",
        "-d",
        "chrome",
        "--web-port",
        "8765",
        "--web-hostname",
        "127.0.0.1"
      ],
      "cwd": "frontend",
      "port": 8765
    },
    {
      "name": "flutter-web-static",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8766"],
      "cwd": "frontend/build/web",
      "port": 8766
    }
  ]
}
